# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/gateway

# Redis
REDIS_URL=redis://localhost:6379

# JWT (Merchant Dashboard)
JWT_SECRET=your-jwt-secret-min-32-chars-long
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long

# JWT (Android Device)
DEVICE_JWT_SECRET=your-device-jwt-secret-min-32-chars
DEVICE_JWT_REFRESH_SECRET=your-device-refresh-secret-min-32-chars

# JWT (Admin Panel)
ADMIN_JWT_SECRET=your-admin-jwt-secret-min-32-chars
ADMIN_JWT_REFRESH_SECRET=your-admin-refresh-secret-min-32-chars

# Internal (Detection Engine)
INTERNAL_API_KEY=your-internal-api-key

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key

# App URLs
BACKEND_URL=http://localhost:3001
CHECKOUT_URL=http://localhost:3002
DASHBOARD_URL=http://localhost:3003
ADMIN_URL=http://localhost:3004

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug
