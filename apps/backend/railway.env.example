# Railway backend service variables (set in Railway → Service → Variables)
# Add PostgreSQL and Redis plugins first, then reference their URLs.

DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}

JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-a-random-string-at-least-32-chars
DEVICE_JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
DEVICE_JWT_REFRESH_SECRET=change-me-to-a-random-string-at-least-32-chars
ADMIN_JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
ADMIN_JWT_REFRESH_SECRET=change-me-to-a-random-string-at-least-32-chars
INTERNAL_API_KEY=change-me-internal-key-16chars

NODE_ENV=production
LOG_LEVEL=info

# Optional on Railway — auto-detected from RAILWAY_PUBLIC_DOMAIN if omitted.
# If set manually, use full URL with https:// (host-only also works: your-backend.up.railway.app)
BACKEND_URL=https://your-backend.up.railway.app
CHECKOUT_URL=http://localhost:3002
DASHBOARD_URL=http://localhost:3003
ADMIN_URL=http://localhost:3004

# Railway sets PORT automatically — do not override unless needed
