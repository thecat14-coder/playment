    "@gateway/shared": "workspace:*",
    "@supabase/supabase-js": "^2.49.0",
    "argon2": "^0.41.0",
    "bullmq": "^5.34.0",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
    "postgres": "^3.4.0",
    "qrcode": "^1.5.0",
    "ulid": "^2.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.0",
